#!/bin/sh
set -eu

case "${1:-}" in
  status)
    if [ "${SPRINT_LOOP_FAKE_MODE:-}" = "status-signal" ]; then
      kill -TERM $$
    fi
    if [ "${SPRINT_LOOP_FAKE_MODE:-}" = "status-nonzero" ]; then
      printf '\033[31mBearer synthetic-token https://user:synthetic-secret@example.test/path?token=synthetic-query\r\n' >&2
      exit 9
    fi
    if [ "${SPRINT_LOOP_FAKE_MODE:-}" = "status-oversized" ]; then
      dd if=/dev/zero bs=1024 count=320 2>/dev/null | tr '\000' x
      exit 0
    fi
    if [ "${SPRINT_LOOP_FAKE_MODE:-}" = "status-malformed" ]; then
      printf '%s\n' '{not-json'
      exit 0
    fi
    if [ "${SPRINT_LOOP_FAKE_MODE:-}" = "status-credential" ]; then
      printf '%s\n' '{"schema_version":1,"controller_version":"0.1.0","sprint_root":"/tmp/synthetic-sprint","run_exists":true,"process_running":false,"run_id":"run-synthetic","sprint":{"multisprint":"foundation","index":3},"state":"blocked","reason":{"code":"unsafe_status","message":"https://example.invalid/path?opaque=synthetic-status-value"},"active":{"role":null,"invocation_id":null,"session_id":null,"status":null,"interaction":null},"commits":{"local":{"managed":null},"pushed":{"managed":null}},"audit":{"phase":null,"pre_ci_round":0,"pre_ci_max_rounds":2,"remaining_effort":null},"ci":{"status":"not_started","attempt":0,"commit_sha":null},"counters":{"implementation_cycles":0,"ci_fix_attempts":0},"checklist":{"satisfied":0,"partial":0,"unsatisfied":0,"not_evaluated":0,"assessed_at":null},"last_event":{"sequence":3,"type":"run.blocked","timestamp":"2026-07-15T12:00:00Z"},"updated_at":"2026-07-15T12:00:00Z"}'
      exit 0
    fi
    if [ "${SPRINT_LOOP_FAKE_MODE:-}" = "status-delayed-active" ]; then
      sleep 0.1
      printf '%s\n' '{"schema_version":1,"controller_version":"0.1.0","sprint_root":"/tmp/synthetic-sprint","run_exists":true,"process_running":true,"run_id":"run-synthetic","sprint":{"multisprint":"foundation","index":3},"state":"validating","reason":null,"active":{"role":"auditor","invocation_id":"0001-auditor","session_id":"ses_synthetic","status":"running","interaction":null},"commits":{"local":{"managed":null},"pushed":{"managed":null}},"audit":{"phase":null,"pre_ci_round":0,"pre_ci_max_rounds":2,"remaining_effort":null},"ci":{"status":"not_started","attempt":0,"commit_sha":null},"counters":{"implementation_cycles":0,"ci_fix_attempts":0},"checklist":{"satisfied":0,"partial":0,"unsatisfied":0,"not_evaluated":0,"assessed_at":null},"last_event":{"sequence":4,"type":"agent.started","timestamp":"2026-07-15T12:00:00Z"},"updated_at":"2026-07-15T12:00:00Z"}'
      exit 0
    fi
    if [ "${SPRINT_LOOP_FAKE_MODE:-}" = "status-interrupted-active" ]; then
      printf '%s\n' '{"schema_version":1,"controller_version":"0.1.0","sprint_root":"/tmp/synthetic-sprint","run_exists":true,"process_running":false,"run_id":"run-synthetic","sprint":{"multisprint":"foundation","index":3},"state":"validating","reason":null,"active":{"role":"auditor","invocation_id":"0001-auditor","session_id":"ses_synthetic","status":"running","interaction":null},"commits":{"local":{"managed":null},"pushed":{"managed":null}},"audit":{"phase":null,"pre_ci_round":0,"pre_ci_max_rounds":2,"remaining_effort":null},"ci":{"status":"not_started","attempt":0,"commit_sha":null},"counters":{"implementation_cycles":0,"ci_fix_attempts":0},"checklist":{"satisfied":0,"partial":0,"unsatisfied":0,"not_evaluated":0,"assessed_at":null},"last_event":{"sequence":4,"type":"agent.started","timestamp":"2026-07-15T12:00:00Z"},"updated_at":"2026-07-15T12:00:00Z"}'
      exit 0
    fi
    if [ -n "${SPRINT_LOOP_FAKE_STATUS_FILE:-}" ]; then
      while IFS= read -r line || [ -n "$line" ]; do printf '%s\n' "$line"; done < "$SPRINT_LOOP_FAKE_STATUS_FILE"
    else
      printf '%s\n' '{"schema_version":1,"controller_version":"0.1.0","sprint_root":"/tmp/sprint","run_exists":false,"process_running":false,"run_id":null,"sprint":null,"state":null,"reason":null,"active":null,"commits":null,"audit":null,"ci":null,"counters":null,"checklist":null,"last_event":null,"updated_at":null}'
    fi
    ;;
  run)
    if [ "${SPRINT_LOOP_FAKE_MODE:-}" = "ca-observation" ]; then
      if [ -z "${SSL_CERT_FILE:-}" ] || [ ! -f "$SSL_CERT_FILE" ] || [ ! -r "$SSL_CERT_FILE" ]; then
        printf '%s\n' 'synthetic CA environment missing' >&2
        exit 8
      fi
      printf '%s\n' 'synthetic CA environment observed'
      exit 0
    fi
    if [ -n "${SPRINT_LOOP_TEST_MARKER:-}" ]; then
      sleep 1
      printf '%s\n' survived > "$SPRINT_LOOP_TEST_MARKER"
    fi
    ;;
  emit-large)
    dd if=/dev/zero bs=1024 count=96 2>/dev/null | tr '\000' o
    dd if=/dev/zero bs=1024 count=96 2>/dev/null | tr '\000' e >&2
    ;;
  observe-ca)
    if [ -z "${SSL_CERT_FILE:-}" ] || [ ! -f "$SSL_CERT_FILE" ] || [ ! -r "$SSL_CERT_FILE" ]; then
      printf '%s\n' 'synthetic CA environment missing' >&2
      exit 8
    fi
    printf '%s\n' 'synthetic CA environment observed'
    ;;
  pause|resume|stop)
    printf '%s\n' feature_not_implemented
    ;;
  *)
    printf '%s\n' 'unknown fake command' >&2
    exit 2
    ;;
esac
